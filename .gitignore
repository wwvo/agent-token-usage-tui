# Rust build artifacts
/target/
**/*.rs.bk
Cargo.lock.bak

# Portable runtime artifacts (written next to the exe)
*.db
*.db-wal
*.db-shm
*.log
/log/
pricing.json

# build.rs downloaded asset (regenerated every build)
/assets/litellm-prices.fallback.json

# CI-scoped release notes (ephemeral; generated per tag build by the
# `extract-release-notes` / `Generate release notes` stage).
# CHANGELOG.md itself is committed and regenerated by `git cliff`, so
# it's deliberately NOT gitignored — only this throw-away scratch file.
release-notes.md

# Editors / IDEs
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# Environment
.env
.envrc

# OS-specific junk
ehthumbs.db
